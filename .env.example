# Resend — get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx

# Email where demo requests and contact messages are sent
CONTACT_EMAIL=contact@rostelhightech.com

# Auth.js — generate with: npx auth secret
AUTH_SECRET=

# Database — Neon PostgreSQL (get free at https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js URL (auto-set by Vercel, only needed locally)
# AUTH_URL=http://localhost:3000
