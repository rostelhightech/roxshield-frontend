generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Auth models (NextAuth / Auth.js) ──

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Business models ──

enum Plan {
  STARTER
  BUSINESS
  ENTERPRISE
  CAMPUS
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      Plan     @default(STARTER)
  sector    String?
  country   String?
  city      String?
  size      Int?
  logo      String?
  sessionTimeoutMinutes Int @default(15)
  isDemo    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  // Business relations
  phishingCampaigns    PhishingCampaign[]
  trainingModules      TrainingModule[]
  emailThreats         EmailThreat[]
  passwordAudits       PasswordAudit[]
  shadowItApps         ShadowItApp[]
  encryptionAudits     EncryptionAudit[]
  complianceFrameworks ComplianceFramework[]
  riskEntries          RiskEntry[]
  activityLogs         ActivityLog[]
}

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String        @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           UserRole      @default(EMPLOYEE)
  department     String?
  position       String?
  phone          String?
  riskScore      Int           @default(50)
  locale         String        @default("fr")
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  accounts       Account[]
  sessions       Session[]

  // Business relations
  phishingResults  PhishingResult[]
  trainingProgress TrainingProgress[]
  activityLogs     ActivityLog[]
  notifications    Notification[]
  badges           UserBadge[]
}

// ── Module 2 : Simulations de Phishing ──

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model PhishingCampaign {
  id             String           @id @default(cuid())
  name           String
  description    String?
  templateType   String // ex: "mobile_money", "bank", "delivery", "internal"
  status         CampaignStatus   @default(DRAFT)
  targetDepts    String[] // départements ciblés
  totalTargets   Int              @default(0)
  sentCount      Int              @default(0)
  clickCount     Int              @default(0)
  reportCount    Int              @default(0)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  results        PhishingResult[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

enum PhishingAction {
  SENT
  OPENED
  CLICKED
  REPORTED
  IGNORED
}

model PhishingResult {
  id         String           @id @default(cuid())
  action     PhishingAction   @default(SENT)
  clickedAt  DateTime?
  reportedAt DateTime?
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   PhishingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@unique([userId, campaignId])
}

// ── Module 3 : Formations ──

model TrainingModule {
  id              String             @id @default(cuid())
  title           String
  description     String?
  category        String // ex: "phishing", "passwords", "social_engineering", "data_protection"
  difficulty      String             @default("beginner") // beginner, intermediate, advanced
  durationMinutes Int                @default(10)
  content         Json? // contenu structuré du module
  quizQuestions   Json? // questions de quiz
  badgeIcon       String?
  badgeName       String?
  isActive        Boolean            @default(true)
  organizationId  String? // null = global, sinon spécifique à une org
  organization    Organization?      @relation(fields: [organizationId], references: [id])
  progress        TrainingProgress[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

enum TrainingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model TrainingProgress {
  id              String         @id @default(cuid())
  status          TrainingStatus @default(NOT_STARTED)
  progressPercent Int            @default(0)
  quizScore       Int?
  completedAt     DateTime?
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId        String
  module          TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([userId, moduleId])
}

// ── Module 5 : Sécurité Email ──

enum ThreatSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ThreatStatus {
  DETECTED
  INVESTIGATING
  BLOCKED
  RESOLVED
}

model EmailThreat {
  id             String         @id @default(cuid())
  type           String // "phishing", "bec", "spear_phishing", "spoofing", "malware"
  subject        String?
  senderEmail    String?
  targetEmail    String?
  targetDept     String?
  severity       ThreatSeverity @default(MEDIUM)
  status         ThreatStatus   @default(DETECTED)
  details        Json?
  detectedAt     DateTime       @default(now())
  resolvedAt     DateTime?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
}

// ── Module 6 : Audit Mots de Passe ──

model PasswordAudit {
  id              String       @id @default(cuid())
  totalAccounts   Int          @default(0)
  weakPasswords   Int          @default(0)
  reusedPasswords Int          @default(0)
  noMfaCount      Int          @default(0)
  mfaEnabled      Int          @default(0)
  avgStrength     Int          @default(0) // 0-100
  issues          Json? // détails des problèmes trouvés
  recommendations Json?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  auditedAt       DateTime     @default(now())
  createdAt       DateTime     @default(now())
}

// ── Module 7 : Shadow IT ──

enum ShadowItRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ShadowItApp {
  id             String       @id @default(cuid())
  appName        String
  category       String // "cloud_storage", "messaging", "ai_tools", "project_mgmt", etc.
  usersCount     Int          @default(0)
  departments    String[]
  riskLevel      ShadowItRisk @default(MEDIUM)
  isApproved     Boolean      @default(false)
  dataExposure   String? // "low", "medium", "high"
  detectedAt     DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── Module 8 : Audit Chiffrement ──

model EncryptionAudit {
  id              String       @id @default(cuid())
  zone            String // "storage", "transit", "endpoints", "email", "cloud"
  score           Int          @default(0) // 0-100
  status          String       @default("warning") // "compliant", "warning", "non_compliant"
  findings        Json? // détails des constats
  recommendations Json?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  auditedAt       DateTime     @default(now())
  createdAt       DateTime     @default(now())
}

// ── Module 4 : GRC & Conformité ──

model ComplianceFramework {
  id             String       @id @default(cuid())
  name           String // "ISO 27001", "NIST CSF", "RGPD", "PCI DSS"
  overallScore   Int          @default(0) // 0-100
  status         String       @default("in_progress") // "compliant", "in_progress", "non_compliant"
  categories     Json? // scores par catégorie
  lastAuditDate  DateTime?
  nextAuditDate  DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model RiskEntry {
  id             String       @id @default(cuid())
  title          String
  description    String?
  category       String // "technical", "human", "process", "compliance"
  likelihood     Int          @default(3) // 1-5
  impact         Int          @default(3) // 1-5
  riskScore      Int          @default(9) // likelihood * impact
  status         String       @default("open") // "open", "mitigating", "accepted", "closed"
  mitigation     String?
  owner          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── Badges & Gamification ──

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique // "first_training", "phishing_hunter", "cyber_defender", etc.
  name        String
  description String
  icon        String      @default("Award") // Lucide icon name
  color       String      @default("from-rht-violet to-rht-violet-light")
  category    String      @default("training") // "training", "phishing", "streak", "special"
  condition   Json? // { type: "trainings_completed", threshold: 1 }
  earnedBy    UserBadge[]
  createdAt   DateTime    @default(now())
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

// ── Activité & Notifications ──

model ActivityLog {
  id             String       @id @default(cuid())
  action         String // "login", "campaign_created", "training_completed", etc.
  description    String?
  metadata       Json?
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String?
  type      String   @default("info") // "info", "warning", "success", "error"
  isRead    Boolean  @default(false)
  link      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
